{
  "name": "thecitynook-serverless",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "start": "NODE_OPTIONS=--no-experimental-require-module serverless offline --httpPort ${PORT:-3005} --stage local --region ap-south-1",
    "mongo:up": "docker rm -f mongodb-local >/dev/null 2>&1 || true && docker run -d --name mongodb-local -p 27017:27017 -e MONGO_INITDB_DATABASE=thecitynook -v mongodb-local-data:/data/db mongo:7",
    "mongo:down": "docker stop mongodb-local && docker rm mongodb-local",
    "mongo:logs": "docker logs -f mongodb-local",
    "deploy": "serverless deploy --stage prod --aws-profile hoistin --region ap-south-1",
    "remove": "serverless remove --stage prod --aws-profile hoistin --region ap-south-1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/aws-lambda": "^8.10.119",
    "@types/jest": "^29.5.3",
    "@types/node": "^20.4.5",
    "jest": "^29.6.2",
    "serverless": "^4.36.1",
    "serverless-offline": "^14.6.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1055.0",
    "@aws-sdk/client-s3": "^3.1052.0",
    "@aws-sdk/client-ses": "^3.741.0",
    "@aws-sdk/lib-dynamodb": "^3.1055.0",
    "@aws-sdk/lib-storage": "^3.1052.0",
    "@aws-sdk/s3-request-presigner": "^3.1052.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.7",
    "firebase-admin": "^13.10.0",
    "jsonwebtoken": "^9.0.2",
    "lambda-multipart-parser": "^1.0.1",
    "moment": "^2.30.1",
    "mongodb": "^6.13.0",
    "mongoose": "^8.12.1",
    "sharp": "^0.34.5"
  }
}
